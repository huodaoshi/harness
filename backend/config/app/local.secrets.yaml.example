# 复制为 local.secrets.yaml（已 gitignore），填入真实密钥。勿提交 local.secrets.yaml。
#
# 生产/CI 也可用系统环境变量覆盖（见 conf/connection_env.go）：
#   ARK_API_KEY、ARK_MODEL_ID、JWT_SECRET、MONGODB_URI 等

llm:
  api_key: "your-ark-api-key"
  model: "your-ark-model-id"
  base_url: "https://ark.cn-beijing.volces.com"

