# Harness backend — 复制为 .env 后填写（勿提交 .env）

# 在 backend/ 目录启动；YAML 见 config/app/config.yaml，加载见 conf 包
APP_ENV=local
HTTP_ADDR=:8080
USE_MEMORY_STORE=true
JWT_SECRET=change-me-local-dev-only
REDIS_ADDR=127.0.0.1:6379
LLM_PROVIDER=ark

# 火山方舟 / 豆包（wellness /v1 与 /api/bytedance 代理）
ARK_API_KEY=
ARK_MODEL_ID=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com

# NextChat 兼容代理（第一期）
BYTEDANCE_API_KEY=
BYTEDANCE_URL=https://ark.cn-beijing.volces.com
OPENAI_API_KEY=
# BASE_URL=

# 模型列表（与 NextChat CUSTOM_MODELS 同格式）
# CUSTOM_MODELS=-all,+豆包-Pro@bytedance=ep-xxxxxxxx
# DEFAULT_MODEL=豆包-Pro

# 访问口令（可选，对应 NextChat CODE）
# CODE=

# 关怀模式：为 on 时 /api 聊天也走 SafetyGate（第一期可仅打日志）
# SAFETY_GATE_API=
