# Harness 自有代码：4 空格缩进（排除 vendor 对照目录见下方）
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
tab_width = 4

[*.go]
indent_style = tab
tab_width = 4

[NextChat/**]
indent_size = 2

[lobehub/**]
indent_size = 2

[cli/**]
indent_size = 2
