# CLI (vendored vercel-labs/skills)
cli/node_modules/
cli/dist/
cli/coverage/
cli/out/
cli/*.tgz
cli/*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/

# Env（backend 不用 .env；见 config/app/README.md）
.env
.env.*
!.env.example
!**/.env.example
backend/config/app/*.secrets.yaml
